# Generated by swiftdeploy — do not edit manually
# Source of truth: manifest.yaml

networks:
  {{ network_name }}:
    driver: {{ network_driver }}

volumes:
  {{ log_volume }}:

services:
  app:
    image: {{ service_image }}
    container_name: swiftdeploy-app
    restart: {{ restart_policy }}
    environment:
      - MODE={{ mode }}
      - APP_VERSION={{ app_version }}
      - APP_PORT={{ service_port }}
    networks:
      - {{ network_name }}
    volumes:
      - {{ log_volume }}:/app/logs
    expose:
      - "{{ service_port }}"
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    user: "appuser"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ service_port }}/healthz')"]
      interval: 10s
      timeout: 5s
      retries: 6
      start_period: 10s

  nginx:
    image: {{ nginx_image }}
    container_name: swiftdeploy-nginx
    restart: {{ restart_policy }}
    ports:
      - "80:80"
      - "443:443"
    networks:
      - {{ network_name }}
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./certs/fullchain.pem:/etc/nginx/certs/fullchain.pem:ro
      - ./certs/privkey.pem:/etc/nginx/certs/privkey.pem:ro
      - {{ log_volume }}:/var/log/nginx
    depends_on:
      app:
        condition: service_healthy

  opa:
    image: openpolicyagent/opa:latest-rootless
    container_name: swiftdeploy-opa
    restart: {{ restart_policy }}
    # Bound to localhost only — reachable by the CLI on this host
    # but NOT reachable from the public internet
    # Nginx never proxies to this port — policy API stays private
    ports:
      - "127.0.0.1:8181:8181"
    networks:
      - {{ network_name }}
    volumes:
      # Mount the entire policies/ directory so OPA loads all .rego files
      - ./policies:/policies:ro
    command:
      - "run"
      - "--server"
      - "--addr=0.0.0.0:8181"
      # Load all policy files from the mounted directory
      - "/policies"
    healthcheck:
      test: ["CMD", "sh", "-c", "wget -qO- http://localhost:8181/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 6
      start_period: 10s
